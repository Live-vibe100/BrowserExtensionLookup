<Window x:Class="BrowserExtensionLookup.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:BrowserExtensionLookup.Views"
        Title="Browser Extension Lookup"
        Width="1280" Height="820" MinWidth="1000" MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI" FontSize="13">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Height="56" Background="{StaticResource HeaderBrush}"
                BorderBrush="{StaticResource AccentBrush}" BorderThickness="0,0,0,2" Padding="24,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right" Text="v3.0" VerticalAlignment="Center"
                           Foreground="{StaticResource TextMutedBrush}"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Browser Extension Lookup" FontSize="20" FontWeight="SemiBold"/>
                    <TextBlock Text="Intune Policy Helper" FontSize="12" Margin="14,7,0,0"
                               Foreground="{StaticResource TextMutedBrush}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Clickable tab bar -->
        <Border Grid.Row="1" Background="{StaticResource HeaderBrush}"
                BorderBrush="#333333" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="12,0,0,0" Height="44">
                <RadioButton x:Name="TabSearch" Style="{StaticResource TabButton}" GroupName="Tabs"
                             Content="Search by Name" IsChecked="True" Checked="Tab_Checked"/>
                <RadioButton x:Name="TabLookup" Style="{StaticResource TabButton}" GroupName="Tabs"
                             Content="Lookup by ID" Checked="Tab_Checked"/>
                <RadioButton x:Name="TabBulk" Style="{StaticResource TabButton}" GroupName="Tabs"
                             Content="Bulk Lookup" Checked="Tab_Checked"/>
            </StackPanel>
        </Border>

        <!-- Tab content -->
        <Grid Grid.Row="2" Margin="16,14">
            <views:SearchView x:Name="SearchTabView"/>
            <views:LookupView x:Name="LookupTabView" Visibility="Collapsed"/>
            <views:BulkView x:Name="BulkTabView" Visibility="Collapsed"/>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="3" Background="#191919" BorderBrush="#333333"
                BorderThickness="0,1,0,0" Padding="14,7">
            <TextBlock x:Name="StatusText" FontSize="12"
                       Text="Ready - Search by name or look up an extension ID"
                       Foreground="{StaticResource GreenBrush}"/>
        </Border>
    </Grid>
</Window>
