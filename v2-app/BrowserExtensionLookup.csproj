<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RootNamespace>BrowserExtensionLookup</RootNamespace>
    <AssemblyName>BrowserExtensionLookup</AssemblyName>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Version>2.0.0</Version>
    <Authors>Joe Livesey</Authors>
    <Product>Browser Extension Lookup</Product>
    <Description>Look up Chrome and Edge browser extension IDs for Intune policies</Description>
  </PropertyGroup>

</Project>
