<UserControl x:Class="BrowserExtensionLookup.Views.SearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Search input -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MaxWidth="560"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Extension Name:" FontWeight="SemiBold" FontSize="14"
                       VerticalAlignment="Center" Margin="0,0,12,0"/>
            <TextBox x:Name="QueryBox" Grid.Column="1" Style="{StaticResource ModernTextBox}"
                     VerticalAlignment="Center" KeyDown="QueryBox_KeyDown"/>
            <Button x:Name="SearchButton" Grid.Column="2" Content="Search Both Stores"
                    Style="{StaticResource AccentButton}" Margin="14,0,0,0" MinWidth="180"
                    Click="Search_Click"/>
        </Grid>

        <!-- Side-by-side result cards -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Chrome card -->
            <Border Grid.Column="0" Background="{StaticResource CardBrush}" CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="4"/>
                        <RowDefinition Height="44"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Background="{StaticResource ChromeBrush}" CornerRadius="6,6,0,0"/>
                    <DockPanel Grid.Row="1" Margin="14,0,14,0">
                        <Button DockPanel.Dock="Right" Content="Open in browser →" VerticalAlignment="Center"
                                Style="{StaticResource LinkButton}" Click="OpenChrome_Click"/>
                        <TextBlock Text="Chrome Web Store Results" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource ChromeBrush}" VerticalAlignment="Center"/>
                    </DockPanel>
                    <DataGrid x:Name="ChromeGrid" Grid.Row="2" Style="{StaticResource DarkGrid}"
                              MouseDoubleClick="Grid_DoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Extension Name" Binding="{Binding Name}" Width="6*"/>
                            <DataGridTextColumn Header="Extension ID" Binding="{Binding Id}" Width="4*"
                                                ElementStyle="{StaticResource MonoCellText}"/>
                            <DataGridTemplateColumn Width="72" MinWidth="72" CanUserResize="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Copy" Style="{StaticResource CopyButton}" Click="CopyId_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Edge card -->
            <Border Grid.Column="2" Background="{StaticResource CardBrush}" CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="4"/>
                        <RowDefinition Height="44"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Background="{StaticResource EdgeBrush}" CornerRadius="6,6,0,0"/>
                    <DockPanel Grid.Row="1" Margin="14,0,14,0">
                        <Button DockPanel.Dock="Right" Content="Open in browser →" VerticalAlignment="Center"
                                Style="{StaticResource LinkButton}" Click="OpenEdge_Click"/>
                        <TextBlock Text="Edge Add-ons Results" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource EdgeBrush}" VerticalAlignment="Center"/>
                    </DockPanel>
                    <DataGrid x:Name="EdgeGrid" Grid.Row="2" Style="{StaticResource DarkGrid}"
                              MouseDoubleClick="Grid_DoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Extension Name" Binding="{Binding Name}" Width="5*"/>
                            <DataGridTextColumn Header="Developer" Binding="{Binding Developer}" Width="3*"/>
                            <DataGridTextColumn Header="Extension ID" Binding="{Binding Id}" Width="4*"
                                                ElementStyle="{StaticResource MonoCellText}"/>
                            <DataGridTemplateColumn Width="72" MinWidth="72" CanUserResize="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Copy" Style="{StaticResource CopyButton}" Click="CopyId_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
