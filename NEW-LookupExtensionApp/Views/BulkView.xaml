<UserControl x:Class="BrowserExtensionLookup.Views.BulkView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Input area -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MaxWidth="760"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Paste extension IDs (one per line):" FontWeight="SemiBold"
                           FontSize="14" Margin="0,0,0,6"/>
                <TextBox x:Name="IdsBox" Style="{StaticResource ModernTextBox}" Height="88"
                         FontFamily="Consolas" AcceptsReturn="True" TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         VerticalContentAlignment="Top"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="14,24,0,0" VerticalAlignment="Top">
                <Button x:Name="RunButton" Content="Lookup All" Style="{StaticResource AccentButton}"
                        MinWidth="140" Click="Run_Click"/>
                <Button x:Name="CancelButton" Content="Cancel" Style="{StaticResource GhostButton}"
                        MinWidth="140" Margin="0,6,0,0" IsEnabled="False" Click="Cancel_Click"/>
                <Button x:Name="ExportButton" Content="Export CSV" Style="{StaticResource GhostButton}"
                        MinWidth="140" Margin="0,6,0,0" IsEnabled="False" Click="Export_Click"/>
            </StackPanel>
        </Grid>

        <!-- Progress -->
        <Grid Grid.Row="1" x:Name="ProgressPanel" Margin="0,0,0,10" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ProgressBar x:Name="Progress" Height="6" Background="#333333"
                         Foreground="{StaticResource AccentBrush}" BorderThickness="0"/>
            <TextBlock x:Name="ProgressText" Grid.Column="1" Margin="12,0,0,0" FontSize="12"
                       Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
        </Grid>

        <!-- Results card with split Chrome/Edge accent stripe -->
        <Border Grid.Row="2" Background="{StaticResource CardBrush}" CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="{StaticResource ChromeBrush}" CornerRadius="6,0,0,0"/>
                    <Border Grid.Column="1" Background="{StaticResource EdgeBrush}" CornerRadius="0,6,0,0"/>
                </Grid>
                <DataGrid x:Name="ResultGrid" Grid.Row="1" Style="{StaticResource DarkGrid}">
                    <DataGrid.Resources>
                        <Style x:Key="StatusText" TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="Found">
                                    <Setter Property="Foreground" Value="{StaticResource GreenBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="Not Found">
                                    <Setter Property="Foreground" Value="{StaticResource RedBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="Invalid">
                                    <Setter Property="Foreground" Value="{StaticResource OrangeBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="Pending">
                                    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="Cancelled">
                                    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Extension ID" Binding="{Binding Id}" Width="3*"
                                            ElementStyle="{StaticResource MonoCellText}"/>
                        <DataGridTextColumn Header="Chrome Name" Binding="{Binding ChromeName}" Width="4*">
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DarkGridHeader}">
                                    <Setter Property="Foreground" Value="{StaticResource ChromeBrush}"/>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Chrome" Binding="{Binding ChromeStatus}" Width="110"
                                            ElementStyle="{StaticResource StatusText}">
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DarkGridHeader}">
                                    <Setter Property="Foreground" Value="{StaticResource ChromeBrush}"/>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Edge Name" Binding="{Binding EdgeName}" Width="4*">
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DarkGridHeader}">
                                    <Setter Property="Foreground" Value="{StaticResource EdgeBrush}"/>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Edge" Binding="{Binding EdgeStatus}" Width="110"
                                            ElementStyle="{StaticResource StatusText}">
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DarkGridHeader}">
                                    <Setter Property="Foreground" Value="{StaticResource EdgeBrush}"/>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Width="72" MinWidth="72" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Copy" Style="{StaticResource CopyButton}" Click="CopyId_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
